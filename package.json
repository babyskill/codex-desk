{
  "name": "manager-codex",
  "private": true,
  "version": "0.1.0",
  "author": "tai",
  "description": "Desktop app to organize multiple ChatGPT Plus/Codex accounts across macOS and Windows.",
  "homepage": "https://github.com/Tai-DT/manager-codex",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tai-DT/manager-codex.git"
  },
  "bugs": {
    "url": "https://github.com/Tai-DT/manager-codex/issues"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "release:mac": "npm run build && node scripts/publish-release.mjs --mac dmg zip",
    "release:win": "npm run build && node scripts/publish-release.mjs --win nsis portable",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.managercodex.desktop",
    "productName": "Codex Desk",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "identity": null,
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "electron-updater": "^6.8.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1"
  }
}
